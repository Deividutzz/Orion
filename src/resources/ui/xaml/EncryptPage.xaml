<Page x:Class="Orion.main.app.gui.EncryptPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <Page.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFDA03"/>
            <Setter Property="FontFamily" Value="Yatra One"/>
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="24"/>
        </Style>
        
        <Style TargetType="TextBox">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="#FFDA03"/>
            <Setter Property="Foreground" Value="#4B006E"/>
            <Setter Property="FontFamily" Value="Yatra One"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,0,0,0" />
            <Setter Property="MinWidth" Value="50"/>
        </Style>
        
        <Style x:Key = "OutputBox" TargetType="TextBox">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#4B006E"/>
            <Setter Property="FontFamily" Value="Yatra One"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,0,0,0" />
            <Setter Property="MinWidth" Value="50"/>
        </Style>
        
    </Page.Resources>
    
    <Grid>
        
        <Grid.Background>
            <ImageBrush ImageSource="\src\resources\assets\images\OrionImage.png" Stretch="UniformToFill" />
        </Grid.Background>
        
        <Border Background="Transparent"
                Padding="20"
                HorizontalAlignment="Left">
            <StackPanel>
            
                <TextBlock Text="Encrypt your message:" HorizontalAlignment="Left" FontSize="40" Padding="0,0,0,20" />
            
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Paste your message: " />
                    <TextBox Name="EncryptBox" TextChanged="Changed" KeyDown="EnterInput" HorizontalAlignment="Right"/>
                    <Button Name="EncryptBt" Content="Encrypt" Click="Encrypting" HorizontalAlignment="Stretch" Visibility="Collapsed"/>
                </StackPanel>
            
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Introduce the first key: " />
                    <TextBox Name = "FirstKey" KeyDown="EnterInput"/>
                </StackPanel>
            
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Introduce the second key: " />
                    <TextBox Name="SecondKey" KeyDown="EnterInput"/>
                </StackPanel>
            
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Output: " />
                    <TextBox Name="Result" Style="{StaticResource OutputBox}" IsReadOnly="True" HorizontalAlignment="Center" Visibility="Collapsed"/>
                </StackPanel>
                
            </StackPanel>
        </Border>
        
        <!-- 
            
        <Style x:Key = "OutputBox" TargetType="TextBox">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#FFDA03"/>
            <Setter Property="Foreground" Value="#FFDA03"/>
            <Setter Property="FontFamily" Value="Yatra One"/>
            <Setter Property="Padding" Value="0" />
        </Style>
        
         -->
        
        <!-- The logic is the following: StackPanel is a container that decides the
        children that are in it how these should be arranged and designed. For example:
        you declare one stackpanel for having a part of the textboxes configured on the left
        so you will use on that stackpanel the orientation = left, but if you want other buttons or smth else
        to be oriented different at the same time, then create another stackpanel that would configure them differently -->
        
    </Grid>
    
</Page>